{
  "name": "@rolster/styles-foundations",
  "version": "3.1.0",
  "description": "Front-end style pack to develop responsive and mobile projects on the web with Rolster.",
  "sass": "scss/styles.scss",
  "style": "dist/styles.css",
  "author": "Rolster Technology <rolster.developments@gmail.com>",
  "license": "MIT",
  "exports": {
    ".": {
      "sass": "scss/styles.scss",
      "style": "dist/styles.css",
      "default": "dist/styles.css"
    },
    "./components": {
      "sass": "scss/components/index.scss",
      "style": "dist/components.css",
      "default": "dist/components.css"
    },
    "./design-system-bordered": {
      "sass": "scss/design-system-bordered/index.scss",
      "style": "dist/design-system-bordered.css",
      "default": "dist/design-system-bordered.css"
    },
    "./design-system-filled": {
      "sass": "scss/design-system-filled/index.scss",
      "style": "dist/design-system-filled.css",
      "default": "dist/design-system-filled.css"
    },
    "./scss/*": "./scss/*"
  },
  "files": [
    "dist/",
    "fonts/",
    "icons/",
    "scss/"
  ],
  "scripts": {
    "clean": "rimraf ./dist",
    "comp:build": "sass scss/components/index.scss dist/components.css --style=compressed",
    "dsbd:build": "sass scss/design-system-bordered/index.scss dist/design-system-bordered.css --style=compressed",
    "dsfl:build": "sass scss/design-system-filled/index.scss dist/design-system-filled.css --style=compressed",
    "sass:build": "sass scss/styles.scss dist/styles.css --style=compressed",
    "css:prettier": "prettier --write dist/*.css --ignore-path .prettierignore",
    "css:minify": "css-minify -d dist/ -o dist/",
    "rltcss": "rtlcss dist/styles.css dist/styles.rtl.css",
    "lib:build": "npm run sass:build && npm run comp:build && npm run dsbd:build && npm run dsfl:build",
    "lib:compression": "npm run rltcss && npm run css:prettier && npm run css:minify",
    "build": "npm run clean && npm run lib:build && npm run lib:compression",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "css-minify": "^2.0.0",
    "prettier": "^3.1.8",
    "rimraf": "^6.1.3",
    "rtlcss": "^4.1.0",
    "sass": "^1.89.0",
    "sass-migrator": "^2.2.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rolster-developments/styles-foundations"
  },
  "engines": {
    "node": ">=14.13"
  }
}
